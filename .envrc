# direnv opcional: `direnv allow`
# Carga .env del proyecto. No fija modelos ni bloquea agentes.

watch_file .env

dotenv_if_exists .env

export PYTHONPATH="${PWD}/src${PYTHONPATH:+:$PYTHONPATH}"
export PATH="${HOME}/.local/node/current/bin:${HOME}/.local/bin:${PATH}"

# No unset automático de otras keys (libertad).
# Si quieres limpiar solo esta shell: source scripts/openai_dev_shell.sh
