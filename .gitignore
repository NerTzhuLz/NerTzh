# Virtual environment
.venv/
venv/

# Environment (real keys)
.env
.env.local
.env.*.local

# Python cache
__pycache__/
*.pyc
*.pyo
.ruff_cache/

# IDE / other agents (local noise)
.idea/
*.iml
.explyt/
.cursor/
.agents/
.audits/
.claude/
.grok/

# OS
.DS_Store
Thumbs.db

# Build
dist/
build/

# Runtime logs (keep folder)
logs/*
!logs/.gitkeep

# Temp
*.tmp
*.bak

# Secrets / dumps
*.pem
auth.json
backups/

# Context Bridge local store
data/context_bridge.duckdb
data/*.duckdb
data/session_*.json
data/system_inventory.json

# Agent state and machine inventories stay local; use the bridge CLI to share state.
context_bridge/*
!context_bridge/.gitkeep
docs/SYSTEM_INVENTORY.md
output/

# Sweep snapshots can be large; keep structure
logs/runs/**
!logs/runs/.gitkeep
logs/probes/**
!logs/probes/.gitkeep
.env.production
secrets.env
config/private.env
